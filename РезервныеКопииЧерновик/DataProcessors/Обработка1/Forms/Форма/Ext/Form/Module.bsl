&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// 1. Получаем макет по его точному имени "Макет" и извлекаем структуру HTML
	МакетОбъект = ПолучитьОбщийМакет("Макет");
	ОбъектHTML  = МакетОбъект.ПолучитьДокументHTML();
	
	// 2. Готовим инструменты для сборки HTML в текстовую строку
	ЗаписьHTML = Новый ЗаписьHTML;
	ЗаписьHTML.УстановитьСтроку();
	
	// 3. Переводим внутреннюю структуру 1С в HTML-код
	ЗаписьDOM = Новый ЗаписьDOM;
	ЗаписьDOM.Записать(ОбъектHTML, ЗаписьHTML);
	
	// 4. Помещаем готовый текст в ваш строковый реквизит формы
	ПолеСайта = ЗаписьHTML.Закрыть();
КонецПроцедуры
